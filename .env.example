# Copy to .env for local development (outside Docker).
# Inside Docker Compose these are set via the environment: block.

# ── Services ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://promptguard:promptguard@localhost:5432/promptguard
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Gemini API key ────────────────────────────────────────────────────────────
# Get yours at: https://aistudio.google.com/app/apikey
# LiteLLM reads both names, so set both.
GEMINI_API_KEY=AIzaSyCxZ6UBrJWo5Mo4o0inh7J7omb_H3rW36Q
GOOGLE_API_KEY=AIzaSyCxZ6UBrJWo5Mo4o0inh7J7omb_H3rW36Q

# ── Default model (used in POST /prompts if you don't override model_name) ────
# Options:
#   gemini/gemini-2.5-flash              ← recommended (supported on free tier)
#   gemini/gemini-3.5-flash
DEFAULT_MODEL=gemini/gemini-2.5-flash

# ── Regression thresholds (Phase 4) — all relative (0.0–1.0) ─────────────────
REGRESSION_SIMILARITY_DROP_THRESHOLD=0.10
REGRESSION_LATENCY_SPIKE_THRESHOLD=0.50
REGRESSION_COST_SPIKE_THRESHOLD=0.20
